{
  "name": "myapp",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "sync": "npm run sync:pmtiles && npm run sync:parquet",
    "sync:pmtiles": "rclone sync --progress --s3-chunk-size=50M --include=*.pmtiles static/pmtiles r2://hdx-boundaries-explorer/pmtiles",
    "sync:parquet": "rclone sync --progress --s3-chunk-size=50M --include=*.parquet --include=*.csv static/parquet r2://hdx-boundaries-explorer/parquet",
    "download": "npm run download:m49 && npm run download:plan-status && npm run download:iso3166 && npm run download:ocha && npm run download:wfp && npm run download:unhcr && npm run download:salb && npm run download:fao && npm run download:wb && npm run download:unicef && npm run download:basemap && npm run download:provenance && npm run download:stats",
    "download:m49": "python3 scripts/m49.py",
    "download:plan-status": "python3 scripts/plan_status.py",
    "download:iso3166": "python3 scripts/iso3166.py",
    "download:ocha": "./scripts/ocha.sh",
    "download:wfp": "./scripts/wfp.sh",
    "download:unhcr": "./scripts/unhcr.sh",
    "download:salb": "bash scripts/salb.sh",
    "download:fao": "bash scripts/fao.sh",
    "download:wb": "bash scripts/wb.sh",
    "download:unicef": "bash scripts/unicef.sh",
    "download:basemap": "bash scripts/basemap.sh",
    "download:provenance": "bash scripts/provenance.sh",
    "download:stats": "bash scripts/stats.sh",
    "update": "npx npm-check-updates -u && npm install"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^26",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "hyparquet": "^1.26.2",
    "hyparquet-compressors": "^1.1.1",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1"
  }
}
