{
  "name": "myapp",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "sync": "npm run sync:pmtiles && npm run sync:parquet",
    "sync:pmtiles": "rclone sync --progress --s3-chunk-size=50M --include=*.pmtiles static/pmtiles r2://hdx-boundaries-explorer/pmtiles",
    "sync:parquet": "rclone sync --progress --s3-chunk-size=50M --include=*.parquet static/parquet r2://hdx-boundaries-explorer/parquet",
    "download": "npm run download:m49 && npm run download:ocha && npm run download:wfp && npm run download:unhcr && npm run download:osm && npm run download:salb && npm run download:fao && npm run download:wb && npm run download:unicef",
    "download:m49": "python3 scripts/m49.py",
    "download:ocha": "./scripts/ocha.sh",
    "download:wfp": "./scripts/wfp.sh",
    "download:unhcr": "./scripts/unhcr.sh",
    "download:osm": "./scripts/osm.sh",
    "download:salb": "bash scripts/salb.sh",
    "download:fao": "bash scripts/fao.sh",
    "download:wb": "bash scripts/wb.sh",
    "download:unicef": "bash scripts/unicef.sh",
    "update": "npx npm-check-updates -u && npm install"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.53.11",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "hyparquet": "^1.25.1",
    "hyparquet-compressors": "^1.1.1",
    "maplibre-gl": "^5.20.0",
    "pmtiles": "^4.4.0"
  }
}
